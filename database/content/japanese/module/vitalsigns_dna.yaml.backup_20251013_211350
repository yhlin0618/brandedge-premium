# DNA 指標定義（7次元）
dna_metrics:
  # M - 消費金額
  monetary:
    name: "M - 消費金額"
    short_name: "M"
    full_name: "Monetary"
    description: "顧客の総消費金額"
    icon: "💰"
    unit: "円"
    interpretation: "消費金額が高いほど、顧客価値が大きい"

  # R - 最近の購入
  recency:
    name: "R - 最近の購入"
    short_name: "R"
    full_name: "Recency"
    description: "最後の購入からの日数"
    icon: "🕒"
    unit: "日"
    interpretation: "日数が少ないほど、顧客がアクティブ"
    reverse: true  # 数値が小さいほど良い

  # F - 購入頻度
  frequency:
    name: "F - 購入頻度"
    short_name: "F"
    full_name: "Frequency"
    description: "購入の総回数"
    icon: "🔁"
    unit: "回"
    interpretation: "購入回数が多いほど、ロイヤリティが高い"

  # IPT - 購入間隔
  ipt:
    name: "IPT - 購入周期"
    short_name: "IPT"
    full_name: "Inter-Purchase Time"
    description: "平均購入間隔日数"
    icon: "⏱️"
    unit: "日"
    interpretation: "間隔が短いほど、購入頻度が高い"
    reverse: true

  # CAI - 活動指数
  cai:
    name: "CAI - 顧客アクティビティ"
    short_name: "CAI"
    full_name: "Customer Activity Index"
    description: "総合アクティビティ度指標"
    icon: "📈"
    unit: "指数"
    range: [0, 1]
    interpretation: "指数が高いほど、顧客がアクティブ"

  # PCV - 過去価値
  pcv:
    name: "PCV - 過去価値"
    short_name: "PCV"
    full_name: "Past Customer Value"
    description: "履歴総消費価値"
    icon: "💎"
    unit: "円"
    interpretation: "履歴価値が高いほど、顧客が重要"

  # CRI - 安定度指標
  cri:
    name: "CRI - 顧客安定度"
    short_name: "CRI"
    full_name: "Customer Richness Index"
    description: "購入安定性評価"
    icon: "🎯"
    unit: "スコア"
    interpretation: "スコアが高いほど、購入が安定"

  # NES - 顧客ステータス
  nes:
    name: "NES - 顧客ステータス"
    short_name: "NES"
    full_name: "New/Engaged/Sleeping"
    description: "顧客ライフサイクルステータス"
    icon: "🔄"
    unit: "ステータス"
    interpretation: "顧客のアクティブ段階を追跡"

# RFM 分析
rfm_analysis:
  # 11個のRFM顧客グループ
  segments:
    champions:
      name: "Champions"
      japanese_name: "チャンピオン顧客"
      description: "最高の顧客、高頻度高価値で最近購入"
      criteria: "R=5, F=5, M=5"
      icon: "👑"
      color: "#28a745"
      characteristics:
        - "購入頻度が最高"
        - "消費金額が最大"
        - "最近もアクティブ"
        - "ブランドロイヤリティが非常に高い"
      strategy: "最高レベルの待遇を提供し、関係を維持"
      percentage_range: "5-10%"

    loyal_customers:
      name: "Loyal Customers"
      japanese_name: "ロイヤル顧客"
      description: "頻繁に購入し安定した顧客"
      criteria: "R>=3, F>=4"
      icon: "💎"
      color: "#17a2b8"
      characteristics:
        - "購入頻度が高い"
        - "消費が安定"
        - "関係が長期"
      strategy: "ロイヤリティ報酬を提供し、推薦を奨励"
      percentage_range: "10-15%"

    potential_loyalists:
      name: "Potential Loyalists"
      japanese_name: "潜在ロイヤル顧客"
      description: "最近購入しロイヤル顧客になる可能性がある"
      criteria: "R>=4, F>=2, M>=3"
      icon: "⭐"
      color: "#ffc107"
      characteristics:
        - "最近購入している"
        - "一定の消費がある"
        - "育成価値が高い"
      strategy: "会員プログラムを提供し、インタラクションを増やす"
      percentage_range: "10-15%"

    recent_customers:
      name: "Recent Customers"
      japanese_name: "新規顧客"
      description: "最近初回購入した新規顧客"
      criteria: "R>=4, F=1"
      icon: "🆕"
      color: "#20c997"
      characteristics:
        - "参加したばかり"
        - "育成が必要"
        - "可能性は未知"
      strategy: "新規顧客特典を提供し、信頼を構築"
      percentage_range: "15-20%"

    promising:
      name: "Promising"
      japanese_name: "有望顧客"
      description: "最近購入し、消費金額が大きい"
      criteria: "R>=3, F<=2, M>=4"
      icon: "💫"
      color: "#6610f2"
      characteristics:
        - "客単価が高い"
        - "頻度は向上の余地あり"
        - "成長の可能性あり"
      strategy: "クロスセルで頻度を向上"
      percentage_range: "5-10%"

    need_attention:
      name: "Need Attention"
      japanese_name: "要注意"
      description: "かつて良い顧客だったが、最近購入していない"
      criteria: "R<=3, F>=3, M>=3"
      icon: "⚠️"
      color: "#fd7e14"
      characteristics:
        - "過去のパフォーマンスが良好"
        - "最近冷めている"
        - "再活性化が必要"
      strategy: "ケアメッセージと限定オファーを送信"
      percentage_range: "5-10%"

    about_to_sleep:
      name: "About to Sleep"
      japanese_name: "スリープ寸前"
      description: "購入頻度が低下し、チャーンリスクあり"
      criteria: "R<=3, F<=3, M>=2"
      icon: "😴"
      color: "#e83e8c"
      characteristics:
        - "アクティビティが低下"
        - "チャーンの兆候"
        - "活性化が必要"
      strategy: "パーソナライズオファーで再吸引"
      percentage_range: "10-15%"

    at_risk:
      name: "At Risk"
      japanese_name: "リスク"
      description: "かつてロイヤル顧客だったが、今はチャーンリスクあり"
      criteria: "R<=2, F>=3, M>=3"
      icon: "🚨"
      color: "#dc3545"
      characteristics:
        - "過去の価値が高い"
        - "長期間購入していない"
        - "チャーンリスクが大きい"
      strategy: "緊急回復、原因を理解"
      percentage_range: "5-10%"

    cant_lose_them:
      name: "Can't Lose Them"
      japanese_name: "失えない顧客"
      description: "高価値顧客だが、長期間購入していない"
      criteria: "R<=2, F>=4, M>=5"
      icon: "💔"
      color: "#721c24"
      characteristics:
        - "履歴価値が非常に高い"
        - "チャーンリスクが非常に大きい"
        - "必ず回復が必要"
      strategy: "最高優先度で回復、上層部が介入"
      percentage_range: "2-5%"

    hibernating:
      name: "Hibernating"
      japanese_name: "休眠顧客"
      description: "長期間購入していない"
      criteria: "R<=2, F<=2, M<=2"
      icon: "💤"
      color: "#6c757d"
      characteristics:
        - "長期間インタラクションなし"
        - "低価値"
        - "再活性化コストが高い"
      strategy: "低コストで再活性化を試みる"
      percentage_range: "10-15%"

    lost:
      name: "Lost"
      japanese_name: "離脱顧客"
      description: "チャーンした顧客"
      criteria: "R<=1, F<=2, M<=2"
      icon: "❌"
      color: "#343a40"
      characteristics:
        - "すでにチャーン"
        - "価値が低い"
        - "投資は推奨しない"
      strategy: "原因を記録し、製品/サービスを改善"
      percentage_range: "10-20%"

