    marketing_recommendations:
      name: "Marketing Recommendations"
      description: "Marketing strategy recommendations for different segments"
      prompt_category: "dna_marketing_recommendations"
      icon: "💡"

    churn_prediction:
      name: "Churn Prediction"
      description: "Identify churn risk and provide recovery strategies"
