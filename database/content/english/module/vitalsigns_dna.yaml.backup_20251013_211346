      description: "Discover potential cross-selling opportunities"
      prompt_category: "cross_sell_opportunities"
      icon: "🎁"

# Attribute Extraction
attribute_extraction:
  title: "DNA Attribute Extraction"
  description: "Extract key attributes and characteristics from customer behavior"

  methods:
    ai_extraction:
      name: "AI Auto Extraction"
      description: "Use AI to automatically identify and extract attributes"
      max_attributes: 30
      min_attributes: 5

    rule_based:
      name: "Rule-based Extraction"
      description: "Extract attributes based on predefined rules"

  attribute_categories:
    behavioral:
      name: "Behavioral Attributes"
      description: "Purchase behavior related features"
      examples: ["High frequency purchasing", "Night shopping preference", "Weekend shopping"]

    value_based:
      name: "Value Attributes"
      description: "Spending value related features"
      examples: ["High order value", "Discount sensitive", "Quality oriented"]

    loyalty:
      name: "Loyalty Attributes"
      description: "Loyalty related features"
      examples: ["Long-term customer", "Brand advocate", "Referrer"]

# Chart Configuration
charts:
  histogram_title: "Distribution Histogram"
  # Metric Distribution Histogram
  metric_histogram:
    title: "{metric} Distribution"
    x_axis: "{metric}"
    y_axis: "Customer Count"
    tooltip: "{bin}: {count} customers"

  # Scatter Plot
  scatter_plot:
    title: "{x_metric} vs {y_metric}"
    x_axis: "{x_metric}"
    y_axis: "{y_metric}"
    tooltip: "Customer {id}: {x}={x_value}, {y}={y_value}"

  # Clustering Result Scatter Plot
  clustering_scatter:
    title: "Customer Clustering Results"
    x_axis: "Dimension 1"
    y_axis: "Dimension 2"
    tooltip: "Segment {segment}: {count} customers"

  # RFM Heatmap
  rfm_heatmap:
    title: "RFM Distribution Heatmap"
    x_axis: "Frequency (F)"
    y_axis: "Recency (R)"
    color: "Monetary (M)"
    tooltip: "R={r}, F={f}, M={m}: {count} customers"

  # Segment Feature Radar Chart
  segment_radar:
    title: "Segment Feature Radar Chart"
    dimensions: ["M", "R", "F", "IPT", "CAI", "PCV", "CRI"]
    tooltip: "{segment} - {dimension}: {value}"

  # Lifecycle Distribution
  lifecycle_pie:
    title: "Customer Lifecycle Distribution"
    tooltip: "{stage}: {count} customers ({percentage}%)"

  # Elbow Chart
  elbow_chart:
    title: "Optimal Cluster Number Analysis (Elbow Method)"
    x_axis: "Number of Clusters"
    y_axis: "SSE (Within-cluster Sum of Squares)"
    tooltip: "{k} clusters: SSE = {sse}"

  # Silhouette Chart
  silhouette_chart:
    title: "Optimal Cluster Number Analysis (Silhouette Coefficient)"
    x_axis: "Number of Clusters"
    y_axis: "Average Silhouette Coefficient"
    tooltip: "{k} clusters: coefficient = {score}"

