# スマートセグメント化
clustering:
  methods:
    kmeans:
      name: "K-means クラスタリング"
      description: "クラスタ数に基づくセグメント化"
      parameters:
        - "クラスタ数 (k)"
        - "使用する指標"

    hierarchical:
      name: "階層的クラスタリング"
      description: "階層構造に基づくセグメント化"
      parameters:
        - "距離測定方法"
        - "リンケージ方法"

    dbscan:
      name: "DBSCAN"
      description: "密度に基づくセグメント化"
      parameters:
        - "最小ポイント数"
        - "距離閾値"

